{
	"description": "Test `format=googlebar` html output (#1018)",
	"setup": [
		{
			"page": "Has SRFGooglebar01 value",
			"namespace": "SMW_NS_PROPERTY",
			"contents": "[[Has type::Number]]"
		},
		{
